.obsidian/

# cache dello strumento di lint/format Python (rigenerata)
.ruff_cache/

# artefatti derivati dello strato output: il sorgente .md è la fonte unica,
# il PDF si rigenera con md2pdf quando serve stamparlo o distribuirlo
*.pdf

# fonti grezze (i1): binari sotto copyright, repo pubblico → non versionati.
# Il manifest di provenienza che alimenta i ## Riferimenti (i3) è la porta-collezione
# sources.md in root (versionata); la cartella sources/ tiene solo i binari ignorati.
sources/*

# membrana host-local verso il Mondo runtime; nessun symlink viene versionato
world
